{
  "title": "DevOps Hello World Dashboard",
  "uid": "devops-hello",
  "version": 1,
  "panels": [
    {
      "id": 1,
      "title": "Visits per Second",
      "type": "graph",
      "targets": [
        {
          "expr": "rate(flask_http_request_duration_seconds_count{endpoint=\"/\"}[1m])",
          "legendFormat": "Requests / sec"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
    },
    {
      "id": 2,
      "title": "Database Query Duration",
      "type": "graph",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(flask_http_request_duration_seconds_bucket{endpoint=\"/\"}[5m]))",
          "legendFormat": "P95 Latency"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
    },
    {
      "id": 3,
      "title": "HTTP Status Codes",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(flask_http_request_total) by (status)",
          "legendFormat": "{{status}}"
        }
      ],
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8}
    }
  ],
  "schemaVersion": 27
}
